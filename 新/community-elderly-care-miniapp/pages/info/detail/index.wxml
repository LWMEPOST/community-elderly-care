<view class="page">
  <view class="hero-card" wx:if="{{detail}}">
    <view class="hero-title">{{detail.title}}</view>
    <view class="hero-text">
      {{detail.infoTypeText}} · {{detail.publisherName || '平台发布'}} · {{detail.publishTimeText}}
    </view>
  </view>

  <view class="section panel" wx:if="{{detail}}">
    <view class="panel-title">正文内容</view>
    <view class="panel-desc">浏览量：{{detail.viewCount || 0}}</view>
    <view style="margin-top: 24rpx; white-space: pre-wrap; line-height: 1.9">{{detail.content}}</view>
  </view>

  <view wx:if="{{loading}}" class="empty">正在加载资讯内容...</view>
</view>
