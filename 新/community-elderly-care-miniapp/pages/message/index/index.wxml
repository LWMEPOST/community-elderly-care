<view class="page">
  <view class="hero-card">
    <view class="hero-title">消息中心</view>
    <view class="hero-text">
      查看和管理员、家属、老人或服务人员之间的会话记录，及时处理未读消息和系统提醒。
    </view>
  </view>

  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-label">未读消息</text>
      <text class="stat-value">{{unreadSummary.totalUnreadCount || 0}}</text>
    </view>
    <view class="stat-card">
      <text class="stat-label">未读会话</text>
      <text class="stat-value">{{unreadSummary.unreadConversationCount || 0}}</text>
    </view>
  </view>

  <view class="section panel">
    <view class="panel-title">会话列表</view>
    <view class="card-list">
      <view
        wx:for="{{conversations}}"
        wx:key="counterpartUserId"
        class="list-card"
        data-id="{{item.counterpartUserId}}"
        data-name="{{item.displayName}}"
        bindtap="openDetail"
      >
        <view class="list-title">{{item.displayName}}</view>
        <view class="list-meta">{{item.counterpartRoleLabel}} · {{item.lastMessageTimeText}}</view>
        <view class="list-meta">{{item.lastMessageTypeLabel}} · {{item.lastMessageContent || '暂无内容'}}</view>
        <view class="chips">
          <view class="chip chip-muted">未读 {{item.unreadCount || 0}}</view>
        </view>
      </view>
      <view wx:if="{{!conversations.length}}" class="empty">暂无消息会话</view>
    </view>
  </view>
</view>
