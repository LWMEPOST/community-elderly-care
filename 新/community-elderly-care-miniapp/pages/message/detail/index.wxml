<view class="page">
  <view class="hero-card">
    <view class="hero-title">{{targetName || '会话详情'}}</view>
    <view class="hero-text">查看当前会话记录并继续回复。</view>
  </view>

  <view class="section panel">
    <view class="panel-title">消息记录</view>
    <view class="card-list">
      <view wx:for="{{messages}}" wx:key="id">
        <view class="message-bubble {{item.fromCurrentUser ? 'message-outbound' : 'message-inbound'}}">
          <view>{{item.content}}</view>
          <view class="message-time">{{item.messageTypeLabel}} · {{item.statusLabel}} · {{item.createTimeText}}</view>
        </view>
      </view>
      <view wx:if="{{!messages.length}}" class="empty">暂无消息记录</view>
    </view>
  </view>

  <view class="section panel">
    <view class="panel-title">发送回复</view>
    <view class="form-grid">
      <textarea class="textarea" value="{{replyContent}}" bindinput="onReplyInput" placeholder="输入回复内容" />
      <button class="button-primary" loading="{{sending}}" bindtap="handleSend">发送</button>
    </view>
  </view>
</view>
