<view class="page">
  <view class="hero-card">
    <view class="hero-title">{{currentUser.realName || currentUser.username}}</view>
    <view class="hero-text">当前身份：{{roleLabel}} · 账号状态：{{statusLabel}}</view>
  </view>

  <view class="section panel">
    <view class="row-between">
      <view>
        <view class="panel-title">基础资料</view>
        <view class="panel-desc">更新手机号、地址和紧急联系人等个人信息。</view>
      </view>
      <button class="button-primary" loading="{{savingUser}}" bindtap="handleSaveUser">保存</button>
    </view>

    <view class="form-grid">
      <view>
        <text class="field-label">姓名</text>
        <input class="field" data-field="realName" value="{{userForm.realName}}" bindinput="onUserInput" />
      </view>
      <view>
        <text class="field-label">手机号</text>
        <input class="field" type="number" data-field="phone" value="{{userForm.phone}}" bindinput="onUserInput" />
      </view>
      <view>
        <text class="field-label">地址</text>
        <input class="field" data-field="address" value="{{userForm.address}}" bindinput="onUserInput" />
      </view>
      <view>
        <text class="field-label">紧急联系人</text>
        <input class="field" data-field="emergencyContact" value="{{userForm.emergencyContact}}" bindinput="onUserInput" />
      </view>
      <view>
        <text class="field-label">紧急联系电话</text>
        <input class="field" type="number" data-field="emergencyPhone" value="{{userForm.emergencyPhone}}" bindinput="onUserInput" />
      </view>
    </view>
  </view>

  <view wx:if="{{currentUser.userType === 1}}" class="section panel">
    <view class="row-between">
      <view>
        <view class="panel-title">老人资料</view>
        <view class="panel-desc">完善年龄、健康状况和位置信息。</view>
      </view>
      <button class="button-primary" loading="{{savingElderly}}" bindtap="handleSaveElderly">保存</button>
    </view>

    <view class="form-grid">
      <view>
        <text class="field-label">年龄</text>
        <input class="field" type="number" data-field="age" value="{{elderlyForm.age}}" bindinput="onElderlyInput" />
      </view>
      <view>
        <text class="field-label">性别</text>
        <input class="field" data-field="gender" value="{{elderlyForm.gender}}" bindinput="onElderlyInput" placeholder="0 女 / 1 男" />
      </view>
      <view>
        <text class="field-label">健康状态</text>
        <input class="field" data-field="healthStatus" value="{{elderlyForm.healthStatus}}" bindinput="onElderlyInput" />
      </view>
      <view>
        <text class="field-label">病史</text>
        <textarea class="textarea" data-field="medicalHistory" value="{{elderlyForm.medicalHistory}}" bindinput="onElderlyInput" />
      </view>
      <view>
        <text class="field-label">经度</text>
        <input class="field" type="digit" data-field="longitude" value="{{elderlyForm.longitude}}" bindinput="onElderlyInput" />
      </view>
      <view>
        <text class="field-label">纬度</text>
        <input class="field" type="digit" data-field="latitude" value="{{elderlyForm.latitude}}" bindinput="onElderlyInput" />
      </view>
    </view>
  </view>

  <view wx:if="{{currentUser.userType === 2}}" class="section panel">
    <view class="panel-title">新增绑定申请</view>
    <view class="form-grid">
      <view>
        <text class="field-label">老人用户ID</text>
        <input class="field" type="number" data-field="elderlyId" value="{{bindingForm.elderlyId}}" bindinput="onBindingInput" />
      </view>
      <view>
        <text class="field-label">关系</text>
        <input class="field" data-field="relation" value="{{bindingForm.relation}}" bindinput="onBindingInput" placeholder="例如：女儿、儿子" />
      </view>
    </view>
    <view class="actions">
      <button class="button-primary" loading="{{savingBinding}}" bindtap="handleCreateBinding">提交申请</button>
    </view>
  </view>

  <view wx:if="{{bindings.length}}" class="section panel">
    <view class="panel-title">绑定列表</view>
    <view class="card-list">
      <view wx:for="{{bindings}}" wx:key="id" class="list-card">
        <view class="list-title">{{item.elderlyName || '--'}} 与 {{item.familyName || '--'}}</view>
        <view class="list-meta">{{item.relation}} · {{item.statusLabel}}</view>
        <view class="actions">
          <button
            wx:if="{{currentUser.userType === 1 && item.status === 0}}"
            class="button-primary"
            data-id="{{item.id}}"
            bindtap="handleConfirmBinding"
          >
            确认绑定
          </button>
        </view>
      </view>
    </view>
  </view>

  <view class="section panel">
    <view class="panel-title">账号操作</view>
    <view class="actions">
      <button class="button-danger" bindtap="handleLogout">退出登录</button>
    </view>
  </view>
</view>
