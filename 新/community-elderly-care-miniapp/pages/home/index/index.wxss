.home-hero {
  padding-top: 44rpx;
}

.home-hero-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.home-hero-note {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.home-note-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.home-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.home-action-card {
  padding: 24rpx;
  border-radius: 26rpx;
  min-height: 224rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(20, 64, 96, 0.05);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.55);
}

.home-action-card-ocean {
  background: linear-gradient(180deg, rgba(28, 117, 188, 0.14), rgba(28, 117, 188, 0.06));
}

.home-action-card-mint {
  background: linear-gradient(180deg, rgba(35, 179, 138, 0.15), rgba(35, 179, 138, 0.06));
}

.home-action-card-rose {
  background: linear-gradient(180deg, rgba(219, 96, 96, 0.16), rgba(219, 96, 96, 0.06));
}

.home-action-card-gold {
  background: linear-gradient(180deg, rgba(221, 159, 56, 0.16), rgba(221, 159, 56, 0.06));
}

.home-action-card-violet {
  background: linear-gradient(180deg, rgba(107, 93, 176, 0.16), rgba(107, 93, 176, 0.06));
}

.home-action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #14588f;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(20, 64, 96, 0.08);
}

.home-action-title {
  margin-top: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #17324d;
  line-height: 1.4;
}

.home-action-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #5f7589;
  line-height: 1.6;
}
