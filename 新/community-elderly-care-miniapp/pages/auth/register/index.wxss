.register-page {
  padding-top: 32rpx;
}

.register-hero {
  padding-top: 40rpx;
}

.register-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.register-note-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.register-note-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.register-panel {
  position: relative;
}

.register-form-grid {
  margin-top: 26rpx;
}

.register-hint-card {
  margin-top: 24rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, rgba(28, 117, 188, 0.08), rgba(28, 117, 188, 0.03));
  border: 1rpx solid rgba(20, 64, 96, 0.06);
}

.register-hint-title {
  color: #17324d;
  font-size: 26rpx;
  font-weight: 700;
}

.register-hint-text {
  margin-top: 10rpx;
  color: #5f7589;
  font-size: 24rpx;
  line-height: 1.6;
}

.register-actions {
  margin-top: 28rpx;
}

.register-submit {
  flex: 1;
}

.register-back {
  min-width: 188rpx;
}
