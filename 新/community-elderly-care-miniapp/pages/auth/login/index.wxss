.auth-page {
  position: relative;
  overflow: hidden;
  padding-top: 36rpx;
}

.auth-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(8rpx);
  opacity: 0.4;
}

.auth-glow-top {
  right: -80rpx;
  top: 40rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(41, 145, 197, 0.28);
}

.auth-glow-bottom {
  left: -100rpx;
  top: 520rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(41, 179, 138, 0.18);
}

.auth-hero,
.auth-panel {
  position: relative;
  z-index: 1;
}

.auth-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 138rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.auth-role-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 28rpx;
}

.auth-role-card {
  padding: 20rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12rpx);
}

.auth-role-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #14588f;
  font-size: 28rpx;
  font-weight: 700;
}

.auth-role-title {
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.auth-role-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  line-height: 1.6;
}

.auth-panel {
  margin-top: 26rpx;
}

.auth-form-grid {
  margin-top: 28rpx;
}

.auth-field-shell {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 104rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f9fbfd, #f4f8fb);
  border: 1rpx solid rgba(20, 64, 96, 0.08);
  box-sizing: border-box;
}

.auth-field-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: rgba(28, 117, 188, 0.1);
  color: #14588f;
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.auth-field-input {
  flex: 1;
  min-width: 0;
  height: 104rpx;
  color: #17324d;
  font-size: 28rpx;
  line-height: 104rpx;
}

.auth-tips {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 24rpx;
}

.auth-tip-item {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(28, 117, 188, 0.06);
  color: #5f7589;
  font-size: 24rpx;
  line-height: 1.55;
}

.auth-actions {
  margin-top: 28rpx;
}

.auth-button-main {
  flex: 1;
}

.auth-button-sub {
  min-width: 188rpx;
}
